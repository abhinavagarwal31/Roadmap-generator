# ─── Firebase Configuration ─────────────────────────────────────────
# Copy this file to .env and fill in your Firebase project credentials.
# Get these from: Firebase Console → Project Settings → Your apps → Web app

VITE_FIREBASE_API_KEY=your-api-key-here
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-app-id

# ─── OpenAI Backend Configuration ─────────────────────────────────────
# This key is read by server/index.js only (never expose it with VITE_).

OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4o-mini
API_PORT=8787

# Demo mode is disabled by default.
# Set to true only when you explicitly want local, no-Firebase demo behavior.
VITE_ENABLE_DEMO_MODE=false
